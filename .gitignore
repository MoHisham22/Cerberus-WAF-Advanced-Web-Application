# ============================================
# Cerberus WAF - .gitignore
# ============================================

# --- بيانات حساسة (لا ترفعها أبداً) ---
docker/.env
docker/waf_config/config.json
docker/waf_config/rootCA.crt
docker/waf_config/rootCA.key
docker/waf_config/server.crt
docker/waf_config/server.key

# --- بيانات قاعدة البيانات (كبيرة وخاصة بالبيئة) ---
docker/waf_data/

# --- ملفات السجلات (Logs) ---
docker/waf_logs/
docker/waf_config/waf-service.log

# --- ملفات ACME/SSL التلقائية ---
docker/waf_acme/

# --- ملفات الـ WAF الثنائية (Binary) الكبيرة ---
docker/waf-service
docker/waf-service-logo-edit

# --- ملفات مؤقتة ---
*.pyc
__pycache__/
*.log
*.pid
*.sock
ibtmp1

# --- ملفات النظام ---
.DS_Store
Thumbs.db
